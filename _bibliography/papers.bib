@article{yang2026infonav,
  abbr        = {IROS},
  title       = {InfoNav: A Unified Value Framework Integrating Semantics Value and Information Gain for Navigation},
  author      = {Yang*, Zhi and Yu, Chengpu and Ferrer, Gonzalo and Xu, Jingchen and Zhang, Baichuan},
  journal     = {IEEE/RSJ International Conference on Intelligent Robots and Systems (IROS)},
  year        = {2026},
  abstract    = {We present InfoNav, a unified value framework for embodied navigation that integrates semantic value and information gain. Our approach features a Fast-Slow dual-system architecture that achieves 20x speedup by decoupling VLM inference from robot control loops. The system combines LLM Agent decision module with DeepSeek-V3 for high-level semantic reasoning and VLM semantic perception with Qwen3-VL/BLIP2 for environment understanding. Validated on HM3D/MP3D datasets and real robots, InfoNav demonstrates strong zero-shot object navigation capabilities.},
  html        = {https://github.com/Pandakingxbc/InfoNav},
  code        = {https://github.com/Pandakingxbc/InfoNav},
  selected    = {true},
  preview     = {infonav.png},
  annotation  = {* First author, Under Review}
}
